# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev.
# For Railway: set these as environment variables in the dashboard.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Backend URLs ────────────────────────────────────────────
# Local dev: http://localhost:8080
# Production: https://your-backend.railway.app
NEXT_PUBLIC_API_URL=https://your-backend.railway.app
NEXT_PUBLIC_WS_URL=wss://your-backend.railway.app/ws

# ── Feature flags ───────────────────────────────────────────
NEXT_PUBLIC_MOCK_API=false

# ── Sentry (get DSN from sentry.io → Project Settings → Client Keys)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXXXXXX
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXXXXXX
# Auth token for source map uploads (CI only — sentry.io → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=
